# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Do not put secrets here:
# - GOOGLE_CLIENT_SECRET → Supabase Edge Function secrets only
# - SUPABASE_SERVICE_ROLE_KEY → never in the browser / Vite env
# - Database password → local tooling only, never commit
